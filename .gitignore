# --- Python & Environment ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv/
env/
venv/
build/
dist/
*.egg-info/

# --- Autonomous Driving Data (CRITICAL) ---
# Ignore the data folder content but keep the folder structure if needed
data/*
!data/.gitkeep

# GLOBAL IGNORE for raw sensor formats
*.bin
*.pcd
*.ply
*.png
*.jpg
*.jpeg

# --- ASSETS ALLOW-LIST ---
# We force Git to track images inside the assets folder 
# even though we ignored them globally above
!assets/
!assets/*.png
!assets/*.jpg
!assets/*.jpeg
!assets/*.gif

# --- Project Specifics ---
outputs/
logs/
*.log

# --- IDEs & System ---
.vscode/
.idea/
.DS_Store
Thumbs.db